    "@workspace/db": "workspace:*",
    "better-auth": "^1.6.23",
    "cookie": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "cookie-signature": "^1.2.2",
    "cors": "^2.8.6",
    "dockerode": "^5.0.1",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.2.0",
    "pino": "^9.14.0",
